{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc", "import", "promise", "node", "svelte"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn",
		"style": "warn",
		"pedantic": "warn"
	},
	"rules": {
		"no-console": "off",
		"no-unused-vars": "warn",
		"node/no-process-env": "off",
		"unicorn/filename-case": "off",
		"unicorn/no-null": "off",
		"unicorn/prefer-top-level-await": "off"
	},
	"ignorePatterns": [
		"node_modules",
		"dist",
		"build",
		"out",
		".svelte-kit",
		"**/.svelte-kit",
		"generated",
		"**/generated",
		"**/*.generated.ts",
		"**/*.gen.ts"
	]
}
