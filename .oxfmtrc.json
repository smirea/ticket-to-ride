{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [
		"node_modules",
		"dist",
		"build",
		"out",
		".svelte-kit",
		"generated",
		"**/generated",
		"**/*.generated.ts",
		"**/*.gen.ts"
	],
	"printWidth": 120,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"arrowParens": "avoid",
	"jsxSingleQuote": true,
	"svelte": true
}
