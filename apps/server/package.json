{
	"name": "@repo/server",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"dev": "bun --env-file=../../.env --env-file=../../.env.local --watch src/index.ts",
		"start": "bun --env-file=../../.env --env-file=../../.env.local src/index.ts",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@repo/shared": "workspace:*"
	}
}
